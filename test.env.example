# smoke 测试使用的环境变量示例。复制成 test.env 并填入真实凭证。
# 真实的 test.env 已在 .gitignore 中忽略，不要提交真实凭证。

OOPZ_DEVICE_ID=
OOPZ_PERSON_UID=
OOPZ_JWT_TOKEN=
OOPZ_PRIVATE_KEY_FILE=
OOPZ_AREA_ID=
OOPZ_CHANNEL_ID=
OOPZ_TARGET_UID=

# WebSocket 联调等待时间（秒）
OOPZ_SMOKE_WS_WAIT_SECONDS=20
# 设成 1 时，smoke 脚本会等待别人往频道里发一条真实消息再结束
OOPZ_SMOKE_EXPECT_WS_MESSAGE=0
